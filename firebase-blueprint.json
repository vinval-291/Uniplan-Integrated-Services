{
  "entities": {
    "Message": {
      "title": "Contact Message",
      "description": "A message sent from the contact form",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Sender's full name" },
        "email": { "type": "string", "format": "email", "description": "Sender's email address" },
        "subject": { "type": "string", "description": "Subject of the message" },
        "message": { "type": "string", "description": "The message content" },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the message was sent" }
      },
      "required": ["name", "email", "subject", "message", "createdAt"]
    },
    "User": {
      "title": "User Profile",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "user"] }
      },
      "required": ["uid", "email", "role"]
    }
  },
  "firestore": {
    "/messages/{messageId}": {
      "schema": "Message",
      "description": "Collection of contact form submissions"
    },
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles and roles"
    }
  }
}
