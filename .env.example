# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Maintenance Mode
# Set to "true" to show the maintenance page to all users
VITE_MAINTENANCE_MODE="false"

# Email Configuration (for contact form notifications)
# --------------------------------------------------
# For Namecheap Private Email: 
# EMAIL_HOST="mail.privateemail.com"
# EMAIL_PORT="465"
# EMAIL_SECURE="true"

# For Namecheap cPanel: 
# EMAIL_HOST="mail.yourdomain.com"
# EMAIL_PORT="465"
# EMAIL_SECURE="true"

# For Gmail: 
# EMAIL_HOST="smtp.gmail.com"
# EMAIL_PORT="465"
# EMAIL_SECURE="true"
# (Note: Gmail requires an "App Password")

EMAIL_HOST="mail.privateemail.com"
EMAIL_PORT="465"
EMAIL_SECURE="true"
EMAIL_USER="info@yourdomain.com"
EMAIL_PASS="your-password"
NOTIFICATION_EMAIL="info@yourdomain.com"
