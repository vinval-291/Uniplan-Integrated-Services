# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Email Configuration (for contact form notifications)
# For Namecheap Private Email: host=mail.privateemail.com, port=465, secure=true
# For Namecheap cPanel: host=mail.yourdomain.com, port=465, secure=true
# For Gmail: host=smtp.gmail.com, port=465, secure=true
EMAIL_HOST="mail.privateemail.com"
EMAIL_PORT="465"
EMAIL_SECURE="true"
EMAIL_USER="info@yourdomain.com"
EMAIL_PASS="your-password"
NOTIFICATION_EMAIL="info@yourdomain.com"
